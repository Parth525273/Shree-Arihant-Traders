# Environment Variables for Backend
# Copy this file to .env and fill in your values

# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────────
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/shree-arihant-traders?retryWrites=true&w=majority

# ─── JWT Secret ───────────────────────────────────────────
# Use any long random string (min 32 characters)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# ─── Cloudinary ───────────────────────────────────────────
# Get this from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── WhatsApp ─────────────────────────────────────────────
# Admin WhatsApp number (with country code, no + or spaces)
# Example: 919876543210 (91 = India code, then 10-digit number)
ADMIN_WHATSAPP=91XXXXXXXXXX

# ─── Frontend URL (for CORS) ──────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Email (Gmail SMTP for password reset) ────────────────
# Steps: myaccount.google.com → Security → App passwords → generate
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=Your Shop Name <your_gmail@gmail.com>
